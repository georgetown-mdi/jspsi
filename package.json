{
  "name": "jspsi",
  "version": "0.0.0",
  "description": "JavaScript implementation of private set intersection for record linkage.",
  "license": "Apache-2.0",
  "author": "Vincent Dorie <vdorie@gmail.com>",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -ws",
    "lint": "eslint .",
    "format": "prettier --write .",
    "formatcheck": "prettier --list-different .",
    "linkcheck": "node scripts/check-doc-links.mjs",
    "check:contributing": "node scripts/check-contributing-scope.mjs",
    "check:pr-checklist": "node scripts/check-pr-checklist.mjs",
    "check:command-inventory": "node scripts/check-command-inventory.mjs",
    "typecheck": "tsc -p packages/core/tsconfig.json --noEmit && tsc -p apps/cli/tsconfig.test.json && tsc -p apps/web/tsconfig.json",
    "test": "npm run test -w packages/core -w apps/cli -w apps/web",
    "test:scripts": "vitest run --project scripts --project repo-scripts",
    "coverage": "npm run coverage -w packages/core -w apps/cli -w apps/web"
  },
  "keywords": [
    "private set intersection",
    "record linkage"
  ],
  "engines": {
    "node": ">=26"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "yaml": "^2.9.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "protobufjs@7.6.4": true,
    "ssh2@1.17.0": true,
    "cpu-features@0.0.10": true,
    "@parcel/watcher": false,
    "unrs-resolver": false,
    "protoc-gen-js": false
  }
}
