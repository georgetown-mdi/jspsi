{
  "extends": "../../tsconfig.base.json",
  // Emit surface only. Tests and tooling configs are typechecked via
  // tsconfig.test.json so this composite project never emits test/*.js or
  // vitest.config.* into dist.
  "include": ["src/**/*.ts"],
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,

    "composite": true,
    "outDir": "dist",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true
  }
}
