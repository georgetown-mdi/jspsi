{
  "name": "@psilink/core",
  "version": "0.1.0",
  "description": "Library for linkage with private set intersection",
  "license": "Apache-2.0",
  "author": "Vincent Dorie <vdorie@gmail.com>",
  "type": "module",
  "main": "./dist/core.cjs",
  "module": "./dist/core.esm.js",
  "types": "./dist/index.d.ts",
  "browser": "./dist/core.umd.js",
  "exports": {
    ".": {
      "import": "./dist/core.esm.js",
      "require": "./dist/core.cjs",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing.esm.js",
      "require": "./dist/testing.cjs",
      "types": "./dist/testing.d.ts"
    }
  },
  "scripts": {
    "build": "rollup -c rollup.config.ts --configPlugin \"@rollup/plugin-typescript={outputToFilesystem:true}\"",
    "clean": "rimraf dist",
    "dev": "rollup -c rollup.config.ts --configPlugin \"@rollup/plugin-typescript={outputToFilesystem:true}\" -w",
    "pretest": "npm run build",
    "test": "vitest run --project unit",
    "test:unit": "vitest run --project unit",
    "test:stress": "vitest run --project stress"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@openmined/psi.js": "file:../../lib/openmined-psi.js-2.0.6-seclink.1.tgz",
    "canonicalize": "^3.0.0",
    "eventemitter3": "^5.0.1",
    "loglevel": "^1.9.2",
    "luxon": "^3.7.2",
    "papaparse": "^5.5.3",
    "re2js": "^2.8.3",
    "uuid": "^14.0.0",
    "yaml": "^2.8.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/luxon": "^3.7.1",
    "@types/papaparse": "^5.3.16",
    "rimraf": "^6.0.1",
    "rollup": "^4.50.0",
    "rollup-plugin-dts": "^6.2.3",
    "tslib": "^2.8.1",
    "vitest": "^4.1.8"
  }
}
