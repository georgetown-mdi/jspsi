{
  "name": "psilink",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "psilink": "./dist/index.js"
  },
  "scripts": {
    "build": "rollup -c rollup.config.ts --configPlugin \"@rollup/plugin-typescript={outputToFilesystem:true}\"",
    "dev": "PKG_DIR=$(pwd) && cd \"$INIT_CWD\" && node --import=tsx \"$PKG_DIR/dist/index.js\"",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:container:up": "cd \"$(git rev-parse --show-toplevel)\" && docker compose --env-file apps/cli/test/container/.env -f apps/cli/test/container/compose.yaml up -d",
    "test:container:down": "cd \"$(git rev-parse --show-toplevel)\" && docker compose --env-file apps/cli/test/container/.env -f apps/cli/test/container/compose.yaml down"
  },
  "dependencies": {
    "@openmined/psi.js": "file:../../lib/openmined-psi.js-2.0.6-seclink.1.tgz",
    "@psilink/core": "file:../../packages/core",
    "loglevel": "^1.9.2",
    "ssh2-sftp-client": "^12.0.1",
    "tslib": "^2.8.1",
    "yaml": "^2.8.1",
    "yargs": "^18.0.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/ssh2-sftp-client": "^9.0.5",
    "@types/yargs": "^17.0.33",
    "rollup": "^4.50.1",
    "tsx": "^4.22.4",
    "vitest": "^4.0.5"
  }
}
